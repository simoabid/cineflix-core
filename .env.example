# Server Configuration
PORT=3005            # Port number for the server
HOST=localhost       # Use '0.0.0.0' to give LAN/internet access
NODE_ENV=development # 'development' | 'production'. Development debuggs, production keeps console clean
# PUBLIC_URL="https://yourdomain.tld" # The public base URL of your CinePro Core instance. Use this when your server is exposed through a public hostname, reverse proxy, or domain. NO TRAILING SLASH.
STREMIO_ADDON=false  # Set to 'true' to enable Stremio addon functionality. Usage: host:port/stremio/manifest.json
CORS_ORIGIN="*"      # CORS origin for the server. Set to '*' to allow all origins, or a specific origin (e.g., 'http://example.com')
MCP_ENABLED=false    # Set to 'true' to enable MCP functionality
INTERNAL_DEBUG=false # Set to 'true' to get non-playable sources too. recommended: false

# TMDB Configuration
TMDB_API_KEY=your_tmdb_api_key_here
TMDB_CACHE_TTL=86400

# Cache Configuration
CACHE_TYPE=memory    # 'memory' | 'redis'

# Redis Configuration (if using Redis cache)
REDIS_HOST=localhost # default Redis host
REDIS_PORT=6379      # default Redis port
REDIS_PASSWORD=      # Redis password if required

# ---------------------------------------------------------------------------
# Option B — Scrape egress proxy (residential / rotating HTTP proxy)
# ---------------------------------------------------------------------------
# Many providers (LookMovie, VixSrc, VidKing, 111Movies/Vidlove, …) block AWS
# datacenter IPs with HTTP 403 / empty responses. Set PROXY_URL so scrapes and
# allowlisted /v1/proxy stream fetches leave via residential egress.
#
# Leave empty or unset to disable (direct egress only — fine on a laptop).
# PROXY_URL="http://user:pass@proxy.example.com:80"
# SCRAPE_PROXY_URL=   # optional alias; takes precedence over PROXY_URL if set
#
# Verify credentials before deploy (expect your residential IP, not 407):
#   curl -x "$PROXY_URL" -sS https://api.ipify.org?format=json
#
# SCRAPE_PROXY_MODE=allowlist   # off | allowlist | all
# SCRAPE_PROXY_HOSTS=           # comma suffixes; empty = built-in EC2 blocklist
# SCRAPE_PROXY_STREAM=true      # also proxy OMSS /v1/proxy upstream when host matches
# SCRAPE_PROXY_FALLBACK_DIRECT=true  # if proxy hop fails, retry once direct (default true)
#
# PROXY_URL is for stream scrapers only — not for subtitle file downloads.

# ---------------------------------------------------------------------------
# Path B — Subtitles (Wyzie multi-key rotation)
# ---------------------------------------------------------------------------
# 1) Core GET /v1/subtitles → Wyzie search (keys on server only)
# 2) Returns raw opensubtitles.org CDN URLs
# 3) SPA downloads files in the browser (user IP; CORS allows *)
#
# Free keys: https://store.wyzie.io/redeem (~1000 req/day each).
# NEVER put keys in VITE_* — route SPA through GET /v1/subtitles.
#
# WYZIE_API_KEY=wyzie-xxxxxxxx
# WYZIE_API_KEYS=wyzie-key1,wyzie-key2,wyzie-key3
# WYZIE_API_BASE=https://sub.wyzie.io
