{
    "name": "@cinepro/core",
    "version": "1.0.0",
    "type": "module",
    "scripts": {
        "dev": "tsx watch src/server.ts",
        "build": "tsc && npm run copy:wasm",
        "copy:wasm": "mkdir -p dist/providers/vidsrc/wasm dist/providers/vidsync/wasm && cp src/providers/vidsrc/wasm/img_data.js src/providers/vidsrc/wasm/img_data_bg.wasm dist/providers/vidsrc/wasm/ && cp src/providers/vidsync/wasm/bro.wasm dist/providers/vidsync/wasm/",
        "start": "npm run build && node dist/server.js",
        "format": "prettier --write src",
        "clean": "npx rimraf dist"
    },
    "dependencies": {
        "@omss/framework": "^1.1.26",
        "cheerio": "^1.2.0",
        "crypto-js": "^4.2.0",
        "dotenv": "^16.4.5",
        "hls-parser": "^0.10.7",
        "iso-639-1": "^3.1.3",
        "nanoid": "^5.1.5",
        "set-cookie-parser": "^2.7.1",
        "undici": "^6.27.0",
        "unpacker": "^1.0.1"
    },
    "devDependencies": {
        "@types/crypto-js": "^4.2.2",
        "@types/node": "^22.7.4",
        "@types/set-cookie-parser": "^2.4.10",
        "prettier": "^3.3.3",
        "tsx": "^4.19.1",
        "typescript": "^5.6.2"
    }
}
